---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServicesPage from "../components/react/ServicesPage.tsx";

const SITE_URL = "https://sudocreate.studio";

const structuredData = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	name: "Premium Web Design, Website Media & Custom Software | Sudo Create",
	description: "Premium website design, website media, custom software development, product design, UI/UX, and tech strategy from a Tampa Bay technology studio for creative industries.",
	url: `${SITE_URL}/services`,
	publisher: { "@id": `${SITE_URL}/#organization` },
};
---

<BaseLayout
	title="Premium Web Design, Website Media & Custom Software | Sudo Create"
	description="Premium website design, website media, custom software development, product design, UI/UX, and tech strategy from a Tampa Bay technology studio for creative industries."
	structuredData={structuredData}
>
	<div class="fixed top-0 left-0 w-full h-full -z-10">
		<img
			class="object-cover w-full h-full"
			src="/lens-background.jpg"
			alt="Sudo Create creative studio background for brand media services"
		/>
	</div>

	<ServicesPage client:load />
</BaseLayout>
