---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServicesPage from "../components/react/ServicesPage.tsx";

const SITE_URL = "https://sudocreate.studio";

const structuredData = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	name: "Tampa Brand Photography, Videography & Websites | Sudo Create",
	description: "Cinematic Tampa brand photography, brand videography, and creative websites for hospitality, wellness, lifestyle, and property brands.",
	url: `${SITE_URL}/services`,
	publisher: { "@id": `${SITE_URL}/#organization` },
};
---

<BaseLayout
	title="Tampa Brand Photography, Videography & Websites | Sudo Create"
	description="Cinematic Tampa brand photography, brand videography, and creative websites for hospitality, wellness, lifestyle, and property brands."
	structuredData={structuredData}
>
	<div class="fixed top-0 left-0 w-full h-full -z-10">
		<img
			class="object-cover w-full h-full"
			src="/lens-background.jpg"
			alt="Sudo Create creative studio background for brand media services"
		/>
	</div>

	<ServicesPage client:load />
</BaseLayout>
