---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServicesPage from "../components/react/ServicesPage.tsx";

const SITE_URL = "https://sudocreate.studio";

const structuredData = {
	"@context": "https://schema.org",
	"@type": "WebPage",
	name: "Services | Sudo Create",
	description: "Custom websites, software, and media infrastructure for music brands, photographers, founders, and creators — Sudo Create builds creative technology at the intersection of technology and culture.",
	url: `${SITE_URL}/services`,
	publisher: { "@id": `${SITE_URL}/#organization` },
};
---

<BaseLayout
	title="Services | Sudo Create"
	description="Custom websites, software, and media infrastructure for music brands, photographers, founders, and creators — Sudo Create builds creative technology at the intersection of technology and culture."
	structuredData={structuredData}
>
	<div class="fixed top-0 left-0 w-full h-full -z-10">
		<img
			class="object-cover w-full h-full"
			src="/lens-background.jpg"
			alt=""
		/>
	</div>

	<ServicesPage client:load />
</BaseLayout>
