---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="max-w-6xl mx-auto px-6 py-24 dot-grid scanlines">
    <p class="font-mono text-phosphor-amber text-sm tracking-widest mb-4">
      &gt; SUDO CREATE // PORTFOLIO
    </p>
    <h1 class="font-display text-5xl md:text-7xl text-paper leading-tight mb-6">
      Design.<br />Build.<br />Ship.
    </h1>
    <p class="font-body text-paper/70 text-xl max-w-xl mb-10">
      Independent studio for brands that want work that actually does something.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="/work"
        class="font-mono text-sm px-6 py-3 border border-phosphor-amber text-phosphor-amber hover:bg-phosphor-amber hover:text-ink transition-colors tracking-wider"
      >
        VIEW WORK →
      </a>
      <a
        href="/services"
        class="font-mono text-sm px-6 py-3 border border-paper/30 text-paper/60 hover:border-paper hover:text-paper transition-colors tracking-wider"
      >
        SERVICES
      </a>
    </div>
  </section>
</BaseLayout>
