---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorksGrid from "../components/react/WorksGrid.tsx";

const SITE_URL = "https://sudocreate.studio";

const structuredData = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	name: "Brand Photography & Creative Work | Sudo Create",
	description: "Selected brand photography, videography, and website work for Tampa Bay hospitality, wellness, lifestyle, and property brands.",
	url: `${SITE_URL}/works`,
	publisher: { "@id": `${SITE_URL}/#organization` },
};
---

<BaseLayout
	title="Brand Photography & Creative Work | Sudo Create"
	description="Selected brand photography, videography, and website work for Tampa Bay hospitality, wellness, lifestyle, and property brands."
	structuredData={structuredData}
>
	<div class="fixed top-0 left-0 w-full h-full -z-10">
		<img
			class="object-cover w-full h-full"
			src="/lens-background.jpg"
			alt="Cinematic background behind Sudo Create creative work"
		/>
	</div>

	<section class="max-w-6xl mx-auto px-6 pt-32 pb-16 text-white">
		<div class="max-w-2xl flex flex-col gap-4">
			<span class="text-sm uppercase tracking-widest text-white/40"
				>Our Work</span
			>
			<h1 class="text-4xl md:text-6xl font-bold leading-tight">
				Selected visual work.
			</h1>
			<p class="text-white/60 text-base md:text-xl leading-relaxed">
				Brand photography, video, websites, and visual direction for brands
				that need the first look to carry weight. Projects marked <span
					class="inline-flex items-center gap-1 border border-white/30 text-white/70 text-xs px-2 py-0.5 rounded-full align-middle mx-1"
					><span
						class="w-1.5 h-1.5 rounded-full bg-white/70 inline-block"
					></span>Case Study</span
				> include process, decisions, and outcomes.
			</p>
		</div>
	</section>

	<section class="max-w-6xl mx-auto px-6 pb-32 text-white">
		<WorksGrid client:load />
	</section>
</BaseLayout>
