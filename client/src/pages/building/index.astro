---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout>
	<section class="min-h-screen w-full bg-pitch-black relative flex items-center">
		<div
			class="absolute inset-0 z-0"
			style={{
				background: `
          radial-gradient(ellipse 120% 80% at 30% 40%, rgba(255, 20, 147, 0.12), transparent 50%),
          radial-gradient(ellipse 100% 60% at 70% 70%, rgba(255, 215, 0, 0.08), transparent 50%),
          #000000
        `,
			}}
		>
			<div class="max-w-3xl mx-auto px-4 relative py-24">
				<span class="font-light block -mb-2">things we're building</span>
				<h1 class="text-6xl font-light mt-8">the future is in beta.</h1>
				<p class="text-sm mt-6 max-w-xl">
					We're not just building for clients. We're building tools, experiments, and
					products that push the boundaries of what's possible on the web.
				</p>
			</div>
		</div>
	</section>

	<section class="min-h-screen py-24">
		<div class="max-w-4xl mx-auto">
			<div class="space-y-12">
				<div class="border-l-2 border-coral-glow/50 pl-6">
					<span class="text-xs text-white/50">in development</span>
					<h3 class="text-3xl font-light mt-2">something exciting</h3>
					<p class="text-sm mt-4 text-white/60 max-w-lg">
						We're cooking up something that'll change how you think about web development.
						Stay tuned.
					</p>
				</div>
				<div class="border-l-2 border-cyan-400/50 pl-6">
					<span class="text-xs text-white/50">experimental</span>
					<h3 class="text-3xl font-light mt-2">another thing</h3>
					<p class="text-sm mt-4 text-white/60 max-w-lg">
						Sometimes the best ideas come from playing around. This is one of those experiments
						that might just become something real.
					</p>
				</div>
				<div class="border-l-2 border-purple-500/50 pl-6">
					<span class="text-xs text-white/50">concept</span>
					<h3 class="text-3xl font-light mt-2">the next big thing</h3>
					<p class="text-sm mt-4 text-white/60 max-w-lg">
						Every great product starts as a wild idea. This one's still in the dreaming phase,
						but not for long.
					</p>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
