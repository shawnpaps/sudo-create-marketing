---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProject } from '../../lib/payload';

export async function getStaticPaths() {
  // Populated once CMS is live
  return [];
}

const { slug } = Astro.params;
let project: Record<string, unknown> | null = null;

try {
  const res = await getProject(slug!);
  project = res.docs[0] ?? null;
} catch {
  // CMS not running locally — fail gracefully
}

if (!project) {
  return Astro.redirect('/work');
}
---

<BaseLayout title={String(project.title ?? slug)}>
  <article class="max-w-4xl mx-auto px-6 py-16">
    <p class="font-mono text-phosphor-amber text-xs tracking-widest mb-2">&gt; /work/{slug}</p>
    <h1 class="font-display text-4xl text-paper mb-4">{String(project.title)}</h1>
    {project.summary && (
      <p class="font-body text-paper/70 text-lg mb-8">{String(project.summary)}</p>
    )}
    <div class="font-mono text-paper/40 text-sm">// body content renders here</div>
  </article>
</BaseLayout>
