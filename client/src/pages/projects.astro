---
import BaseLayout from "../layouts/BaseLayout.astro";
import BuildingPage from "../components/react/BuildingPage.tsx";
---

<BaseLayout
	title="Products | Sudo Create"
	description="Explore Tourpass, a music industry networking platform, and custom software from Sudo Create."
>
	<div class="fixed top-0 left-0 w-full h-full -z-10">
		<img
			class="object-cover w-full h-full"
			src="/lens-background.jpg"
			alt="Tech-forward background behind Sudo Create products"
		/>
	</div>

	<BuildingPage client:load />
</BaseLayout>
