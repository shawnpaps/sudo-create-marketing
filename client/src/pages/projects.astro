---
import BaseLayout from "../layouts/BaseLayout.astro";
import BuildingPage from "../components/react/BuildingPage.tsx";
---

<BaseLayout
	title="Products | Sudo Create"
	description="Explore Tourpass and the media software Sudo Create builds for live events and creative workflows. See what is live."
>
	<div class="fixed top-0 left-0 w-full h-full -z-10">
		<img
			class="object-cover w-full h-full"
			src="/lens-background.jpg"
			alt="Studio lens detail behind Sudo Create products"
		/>
	</div>

	<BuildingPage client:load />
</BaseLayout>
