---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "./react/Hero.tsx";
import FeaturedWorkCarousel from "./react/FeaturedWorkCarousel.tsx";
import ServicesSection from "./react/ServicesSection.tsx";
import TestimonialsSection from "./react/TestimonialsSection.tsx";
import AboutSection from "./react/AboutSection.tsx";
import CTASection from "./react/CTASection.tsx";

interface Props {
	title: string;
	description: string;
	heroHeading: string;
	heroSubtext: string;
	location?: string;
}

const { title, description, heroHeading, heroSubtext, location } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<div class="fixed top-0 left-0 w-full h-full -z-10">
		<img
			class="object-cover w-full h-full"
			src="/lens-background.jpg"
			alt=""
		/>
	</div>

	<Hero
		client:load
		heading={heroHeading}
		subtext={heroSubtext}
		location={location}
	/>

	<section class="max-w-6xl mx-auto px-6 py-16 md:py-24 text-white">
		<h2
			class="border-b-2 w-full mb-10 md:mb-16 text-3xl md:text-4xl font-bold"
		>
			Featured Works
		</h2>
		<FeaturedWorkCarousel client:load />
	</section>

	<section class="max-w-6xl mx-auto px-6 py-16 md:py-24 text-white">
		<h2
			class="border-b-2 w-full mb-10 md:mb-16 text-3xl md:text-4xl font-bold"
		>
			What We Do
		</h2>
		<ServicesSection client:load />
	</section>

	<TestimonialsSection client:load />

	<AboutSection client:load />

	<CTASection client:load />
</BaseLayout>
