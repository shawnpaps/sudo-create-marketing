---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "./react/Hero.tsx";
import BackgroundVideo from "./react/BackgroundVideo.tsx";
import FeaturedWorkCarousel from "./react/FeaturedWorkCarousel.tsx";
import ServicesSection from "./react/ServicesSection.tsx";
import TestimonialsSection from "./react/TestimonialsSection.tsx";
import AboutSection from "./react/AboutSection.tsx";
import CTASection from "./react/CTASection.tsx";

interface Props {
	title: string;
	description: string;
	heroHeading: string;
	heroSubtext: string;
	location?: string;
}

const { title, description, heroHeading, heroSubtext, location } = Astro.props;

const SITE_URL = "https://sudocreate.studio";

const organizationId = `${SITE_URL}/#organization`;

const baseOrganization = {
	"@type": ["Organization", "ProfessionalService"],
	"@id": organizationId,
	name: "Sudo Create",
	url: SITE_URL,
	logo: {
		"@type": "ImageObject",
		url: `${SITE_URL}/sudo_white.png`,
	},
	description:
		"Creative technology studio — custom websites, software, and media infrastructure for creators, music brands, founders, and startups.",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Tampa",
		addressRegion: "FL",
		addressCountry: "US",
	},
};

const homeStructuredData: Record<string, unknown> = {
	"@context": "https://schema.org",
	"@graph": [
		baseOrganization,
		{
			"@type": "WebSite",
			"@id": `${SITE_URL}/#website`,
			url: SITE_URL,
			name: "Sudo Create",
			publisher: { "@id": organizationId },
		},
	],
};

const offerCatalog = {
	"@type": "OfferCatalog",
	name: "Creative Technology Services",
	itemListElement: [
		{ "@type": "Offer", itemOffered: { "@type": "Service", name: "Content-Driven Websites" } },
		{ "@type": "Offer", itemOffered: { "@type": "Service", name: "Custom Software & Apps" } },
		{ "@type": "Offer", itemOffered: { "@type": "Service", name: "Media Infrastructure & CMS" } },
	],
};

const [cityName, stateCode] = location ? location.split(", ") : [];

const localBusinessStructuredData: Record<string, unknown> | null = location
	? {
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"@id": organizationId,
			name: "Sudo Create",
			url: SITE_URL,
			image: `${SITE_URL}/lens-background.jpg`,
			description,
			address: {
				"@type": "PostalAddress",
				addressLocality: cityName,
				addressRegion: stateCode ?? "FL",
				addressCountry: "US",
			},
			areaServed: { "@type": "City", name: cityName },
			hasOfferCatalog: offerCatalog,
		}
	: null;

const structuredData = localBusinessStructuredData ?? homeStructuredData;
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
	<BackgroundVideo
		client:load
		playbackId="LwLeS9iH4T02SdguRAhMAfai7MQ2MErOuePpuL5GTkiU"
	/>

	<Hero
		client:load
		heading={heroHeading}
		subtext={heroSubtext}
		location={location}
	/>

	<section class="max-w-6xl mx-auto px-6 py-16 md:py-24 text-white">
		<h2
			class="border-b-2 w-full mb-10 md:mb-16 text-3xl md:text-4xl font-bold"
		>
			Selected Work
		</h2>
		<FeaturedWorkCarousel client:load />
	</section>

	<section class="max-w-6xl mx-auto px-6 py-16 md:py-24 text-white">
		<div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md p-8 md:p-12">
			<h2
				class="border-b-2 border-white/20 w-full mb-10 md:mb-16 text-3xl md:text-4xl font-bold"
			>
				What We Do
			</h2>
			<ServicesSection client:load />
		</div>
	</section>

	<TestimonialsSection client:load />

	<AboutSection client:load />

	<CTASection client:load />
</BaseLayout>
