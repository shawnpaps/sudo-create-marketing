---
import "../styles/global.css";
import Navigation from "../components/Navigation.astro";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	structuredData?: Record<string, unknown>;
	noIndex?: boolean;
}

const {
	title = "Bespoke Technology Studio for Creative Industries | Sudo Create",
	description = "Sudo Create is a bespoke technology studio in Tampa Bay building premium websites, custom software, product design, and tech strategy for creative brands and startups.",
	ogImage = "/lens-background.jpg",
	structuredData,
	noIndex = false,
} = Astro.props;

const SITE_URL = "https://sudocreate.studio";
const canonical = `${SITE_URL}${Astro.url.pathname}`;
const ogImageAbsolute = `${SITE_URL}${ogImage}`;
const seoKeywords = [
	"bespoke technology studio",
	"Tampa web design studio",
	"custom software development Tampa",
	"product design UI/UX Tampa",
	"technology studio creative industries",
	"premium website design Tampa",
	"tech strategy consulting Tampa",
].join(", ");
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="description" content={description} />
	<meta name="keywords" content={seoKeywords} />
	<meta name="theme-color" content="#000000" />

	{noIndex && <meta name="robots" content="noindex, nofollow" />}

	<!-- Canonical -->
	<link rel="canonical" href={canonical} />

	<!-- Favicons -->
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="icon" href="/favicon.ico" />

	<!-- Open Graph -->
	<meta property="og:type" content="website" />
	<meta property="og:site_name" content="Sudo Create" />
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:url" content={canonical} />
	<meta property="og:image" content={ogImageAbsolute} />
	<meta property="og:image:width" content="1200" />
	<meta property="og:image:height" content="630" />
	<meta property="og:image:alt" content="Sudo Create, a Tampa Bay technology studio" />
	<meta property="og:locale" content="en_US" />

	<!-- Twitter / X Card -->
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={description} />
	<meta name="twitter:url" content={canonical} />
	<meta name="twitter:image" content={ogImageAbsolute} />
	<meta name="twitter:image:alt" content="Sudo Create, a Tampa Bay technology studio" />

	<!-- Preconnect for Mux video -->
	<link rel="preconnect" href="https://stream.mux.com" />
	<link rel="dns-prefetch" href="https://stream.mux.com" />

	<title>{title}</title>

	<!-- Structured Data -->
	{structuredData && (
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	)}
</head>

<body class="min-h-screen flex flex-col tracking-tight font-sans">
	<Navigation />
	<a
		href="/"
		class="fixed top-5 left-5 z-40 opacity-30 hover:opacity-80 transition-opacity duration-300"
		aria-label="Home"
	>
		<img src="/sudo_white.png" alt="Sudo Create" class="h-12 w-auto" />
	</a>
	<main class="flex-1 relative">
		<slot />
	</main>

	<footer class="border-t px-6 py-6">
		<div class="max-w-6xl mx-auto text-sm text-gray-500">
			&copy; {new Date().getFullYear()} Sudo Create
		</div>
	</footer>
</body>
</html>
