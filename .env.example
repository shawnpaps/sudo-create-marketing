# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=sudocreate
POSTGRES_USER=payload
POSTGRES_PASSWORD=changeme

# ── URLs (set these to your actual domain / VPS IP) ───────────────────────────
# Public URL of the CMS — used by Payload for auth redirects and by the client
# browser to call the API.  e.g. https://cms.sudocreate.studio or http://1.2.3.4:3000
CMS_URL=http://localhost:3000

# Public URL of the marketing site — used by Payload for CORS.
# e.g. https://sudocreate.studio or http://1.2.3.4:4321
CLIENT_URL=http://localhost:4321

# ── Payload ───────────────────────────────────────────────────────────────────
PAYLOAD_SECRET=changeme

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-2
