# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=sudocreate
POSTGRES_USER=payload
POSTGRES_PASSWORD=changeme

# ── URLs (set these to your actual domains) ───────────────────────────────────
# Public URL of the CMS — used by Payload for auth redirects and by the client
# browser to call the API.
CMS_URL=https://cms.yourdomain.com

# Public URL of the marketing site — used by Payload for CORS.
CLIENT_URL=https://yourdomain.com

# ── Traefik ───────────────────────────────────────────────────────────────────
# Hostname only (no https://) — used in Traefik Host() routing rules
CMS_HOST=cms.yourdomain.com
CLIENT_HOST=yourdomain.com

# Name of the external Docker network Traefik is attached to
# Run: docker inspect traefik-gwas-traefik-1 --format '{{range $k, $v := .NetworkSettings.Networks}}{{$k}} {{end}}'
TRAEFIK_NETWORK=traefik

# Name of the Let's Encrypt certresolver configured in Traefik
# Run: docker inspect traefik-gwas-traefik-1 --format '{{range .Args}}{{.}} {{end}}' | tr ' ' '\n' | grep certificatesresolvers
TRAEFIK_CERTRESOLVER=letsencrypt

# ── Payload ───────────────────────────────────────────────────────────────────
PAYLOAD_SECRET=changeme

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-2
